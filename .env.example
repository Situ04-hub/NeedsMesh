# NeedsMesh Environment Configuration
# Copy this file to .env and fill in your secrets

# Django Core
SECRET_KEY=Generating-A-New-Secure-Secret-Key-Is-Recommended
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*

# Database Connection String
# For SQLite (default): sqlite:///db.sqlite3
# For PostgreSQL: postgres://user:password@localhost:5432/dbname
DATABASE_URL=sqlite:///db.sqlite3

# Email Settings (for production SMTP)
# EMAIL_URL=smtp://user:password@smtp.gmail.com:587/?tls=True
